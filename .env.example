# ──────────────────────────────────────────────────────
# 한국투자증권 KIS Developers API 설정
# https://apiportal.koreainvestment.com 에서 발급
# ──────────────────────────────────────────────────────

# API 앱 키 / 시크릿
KIS_APP_KEY=발급받은_앱키_여기에_입력
KIS_APP_SECRET=발급받은_앱시크릿_여기에_입력

# 계좌번호 (예: 50123456-01 형식)
KIS_ACCOUNT_NO=계좌번호-상품코드

# 투자 모드
# paper  = KIS 모의투자 (권장: 처음 시작 시)
# real   = KIS 실전투자 (충분히 검증 후 전환)
KIS_MODE=paper

# ── 텔레그램 알림 (선택 사항) ──────────────────────────
# BotFather에서 봇 생성 후 토큰 발급
# https://t.me/BotFather
TELEGRAM_BOT_TOKEN=봇_토큰_여기에_입력
# 본인 채팅 ID 확인: https://t.me/userinfobot
TELEGRAM_CHAT_ID=채팅_ID_여기에_입력
